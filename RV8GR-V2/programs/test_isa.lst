$0000: $30 $10              ;     LI $10          ; AC=$10
$0002: $10 $05              ;     ADDI $05        ; AC=$15
$0004: $90 $15              ;     SUBI $15        ; AC=$00, Z=1
$0006: $70 $AA              ;     XORI $AA        ; AC=$AA, Z=0
$0008: $04 $00              ;     MV $00, a0      ; RAM[0]=$AA
$000A: $04 $01              ;     MV $01, a0      ; RAM[1]=$AA
$000C: $30 $00              ;     LI $00          ; AC=$00
$000E: $38 $00              ;     MV a0, $00      ; AC=RAM[0]=$AA
$0010: $98 $01              ;     SUB $01         ; AC=$AA-$AA=$00, Z=1
$0012: $02 $16              ;     BEQ ok1
$0014: $01 $14              ;     HLT             ; FAIL
$0016: $30 $FF              ;     LI $FF          ; AC=$FF, Z=0
$0018: $02 $1C              ;     BEQ fail1       ; should NOT take (Z=0)
$001A: $82 $1E              ;     BNE ok2         ; should take (Z=0)
$001C: $01 $1C              ;     HLT             ; FAIL
$001E: $04 $02              ;     MV $02, a0      ; RAM[2]=$FF
$0020: $30 $55              ;     LI $55          ; AC=$55
$0022: $18 $02              ;     ADD $02         ; AC=$55+$FF=$54
$0024: $78 $02              ;     XOR $02         ; AC=$54^$FF=$AB
$0026: $20 $10              ;     SETPG $10       ; PG=$10
$0028: $01 $00              ;     J lo(page10)    ; jump to $1000
$1000: $20 $00              ;     SETPG $00       ; PG=$00
$1002: $01 $2E              ;     J lo(back)      ; jump back to $002E
$002E: $30 $80              ;     LI $80          ; AC=$80
$0030: $04 $03              ;     MV $03, a0      ; RAM[3]=$80
$0032: $28 $03              ;     SETPG_R $03     ; PG=RAM[3]=$80 (used below but doesn't matter for $00xx)
$0034: $30 $00              ;     LI $00          ; AC=$00
$0036: $90 $00              ;     SUBI $00        ; AC=$00, Z=1
$0038: $01 $38              ;     HLT             ; ALL PASS

; Labels:
;   start = $0000
;   ok1 = $0016
;   fail1 = $001C
;   ok2 = $001E
;   back = $002E
;   pass = $0038
;   page10 = $1000
