$0000: $30 $00              ;     LI $00          ; AC=0, Z=1
$0002: $10 $01              ;     ADDI $01        ; AC=1
$0004: $10 $FE              ;     ADDI $FE        ; AC=$FF
$0006: $10 $01              ;     ADDI $01        ; AC=$00 (overflow), Z=1
$0008: $02 $0C              ;     BEQ t1ok
$000A: $01 $0A              ;     HLT
$000C: $30 $80              ;     LI $80
$000E: $90 $80              ;     SUBI $80        ; AC=0, Z=1
$0010: $02 $14              ;     BEQ t2ok
$0012: $01 $12              ;     HLT
$0014: $30 $AA              ;     LI $AA
$0016: $70 $FF              ;     XORI $FF        ; $AA^$FF=$55
$0018: $90 $55              ;     SUBI $55        ; =0
$001A: $02 $1E              ;     BEQ t3ok
$001C: $01 $1C              ;     HLT
$001E: $30 $42              ;     LI $42
$0020: $04 $00              ;     MV $00, a0      ; RAM[0]=$42
$0022: $30 $00              ;     LI $00
$0024: $38 $00              ;     MV a0, $00      ; AC=$42
$0026: $90 $42              ;     SUBI $42        ; =0
$0028: $02 $2C              ;     BEQ t4ok
$002A: $01 $2A              ;     HLT
$002C: $30 $33              ;     LI $33
$002E: $04 $01              ;     MV $01, a0      ; RAM[1]=$33
$0030: $30 $11              ;     LI $11
$0032: $04 $02              ;     MV $02, a0      ; RAM[2]=$11
$0034: $30 $00              ;     LI $00
$0036: $18 $01              ;     ADD $01         ; AC=$33
$0038: $18 $02              ;     ADD $02         ; AC=$44
$003A: $98 $01              ;     SUB $01         ; AC=$11
$003C: $98 $02              ;     SUB $02         ; AC=$00, Z=1
$003E: $02 $42              ;     BEQ t5ok
$0040: $01 $40              ;     HLT
$0042: $30 $FF              ;     LI $FF
$0044: $04 $03              ;     MV $03, a0      ; RAM[3]=$FF
$0046: $30 $AA              ;     LI $AA
$0048: $78 $03              ;     XOR $03         ; $AA^$FF=$55
$004A: $90 $55              ;     SUBI $55        ; =0
$004C: $02 $50              ;     BEQ t6ok
$004E: $01 $4E              ;     HLT
$0050: $30 $00              ;     LI $00          ; Z=1
$0052: $02 $56              ;     BEQ t6a         ; taken
$0054: $01 $54              ;     HLT
$0056: $30 $01              ;     LI $01          ; Z=0
$0058: $02 $5C              ;     BEQ t6fail      ; NOT taken (Z=0)
$005A: $01 $5E              ;     J lo(t7ok)
$005C: $01 $5C              ;     HLT
$005E: $30 $01              ;     LI $01          ; Z=0
$0060: $82 $64              ;     BNE t7a         ; taken
$0062: $01 $62              ;     HLT
$0064: $30 $00              ;     LI $00          ; Z=1
$0066: $82 $6A              ;     BNE t7fail      ; NOT taken (Z=1)
$0068: $01 $6C              ;     J lo(t8ok)
$006A: $01 $6A              ;     HLT
$006C: $20 $10              ;     SETPG $10
$006E: $01 $00              ;     J $00           ; → $1000
$0070: $30 $00              ;     LI $00
$0072: $04 $04              ;     MV $04, a0      ; RAM[4]=$00
$0074: $28 $04              ;     SETPG_R $04     ; PG=RAM[4]=$00
$0076: $30 $7C              ;     LI lo(subret)
$0078: $04 $07              ;     MV $07, a0      ; save return addr
$007A: $01 $C0              ;     J lo(mysub)     ; call
$007C: $38 $05              ;     MV a0, $05      ; AC=RAM[5]
$007E: $90 $77              ;     SUBI $77        ; =0 if sub wrote $77
$0080: $02 $84              ;     BEQ pass
$0082: $01 $82              ;     HLT
$0084: $01 $84              ;     HLT
$00C0: $30 $77              ;     LI $77
$00C2: $04 $05              ;     MV $05, a0      ; RAM[5]=$77
$00C4: $20 $00              ;     SETPG $00
$00C6: $01 $7C              ;     J lo(subret)    ; return
$1000: $20 $00              ;     SETPG $00
$1002: $01 $70              ;     J lo(t8ret)     ; back to page $00

; Labels:
;   start = $0000
;   t1ok = $000C
;   t2ok = $0014
;   t3ok = $001E
;   t4ok = $002C
;   t5ok = $0042
;   t6ok = $0050
;   t6a = $0056
;   t6fail = $005C
;   t7ok = $005E
;   t7a = $0064
;   t7fail = $006A
;   t8ok = $006C
;   t8ret = $0070
;   subret = $007C
;   pass = $0084
;   mysub = $00C0
;   page10 = $1000
