$0000: $30 $05              ;     li    5           ; AC = 5
$0002: $04 $03              ;     mv    t0, a0      ; save to r3 (RAM[$03])
$0004: $90 $01              ;     subi  1           ; AC = AC - 1
$0006: $04 $03              ;     mv    t0, a0      ; save counter
$0008: $82 $04              ;     bne   loop        ; if AC != 0, loop back
$000A: $01 $0A              ;     hlt               ; stop

; Labels:
;   start = $0000
;   loop = $0004
;   done = $000A
