$8000: $30 $10              ;     LI $10          ; AC=$10
$8002: $10 $05              ;     ADDI $05        ; AC=$15
$8004: $90 $15              ;     SUBI $15        ; AC=$00, Z=1
$8006: $70 $AA              ;     XORI $AA        ; AC=$AA, Z=0
$8008: $04 $00              ;     MV $00, a0      ; RAM[0]=$AA
$800A: $04 $01              ;     MV $01, a0      ; RAM[1]=$AA
$800C: $30 $00              ;     LI $00          ; AC=$00
$800E: $38 $00              ;     MV a0, $00      ; AC=RAM[0]=$AA
$8010: $98 $01              ;     SUB $01         ; AC=$AA-$AA=$00, Z=1
$8012: $02 $16              ;     BEQ ok1
$8014: $01 $14              ;     HLT             ; FAIL
$8016: $30 $FF              ;     LI $FF          ; AC=$FF, Z=0
$8018: $02 $1C              ;     BEQ fail1       ; should NOT take (Z=0)
$801A: $82 $1E              ;     BNE ok2         ; should take (Z=0)
$801C: $01 $1C              ;     HLT             ; FAIL
$801E: $04 $02              ;     MV $02, a0      ; RAM[2]=$FF
$8020: $30 $55              ;     LI $55          ; AC=$55
$8022: $18 $02              ;     ADD $02         ; AC=$55+$FF=$54
$8024: $78 $02              ;     XOR $02         ; AC=$54^$FF=$AB
$8026: $20 $90              ;     SETPG $90       ; PG=$90
$8028: $01 $00              ;     J lo(page90)    ; jump to $9000
$9000: $20 $80              ;     SETPG $80       ; PG=$80
$9002: $01 $2E              ;     J lo(back)      ; jump back to $802E
$802E: $30 $80              ;     LI $80          ; AC=$80
$8030: $04 $03              ;     MV $03, a0      ; RAM[3]=$80
$8032: $28 $03              ;     SETPG_R $03     ; PG=RAM[3]=$80
$8034: $30 $00              ;     LI $00          ; AC=$00
$8036: $90 $00              ;     SUBI $00        ; AC=$00, Z=1
$8038: $01 $38              ;     HLT             ; ALL PASS