$0000: $30 $42              ;     li    $42         ; AC = $42
$0002: $10 $10              ;     addi  $10         ; AC = $42 + $10 = $52
$0004: $90 $02              ;     subi  $02         ; AC = $52 - $02 = $50
$0006: $04 $03              ;     mv    t0, a0      ; RAM[$03] = $50
$0008: $30 $0A              ;     li    $0A         ; AC = $0A
$000A: $18 $03              ;     add   t0          ; AC = $0A + RAM[$03] = $0A + $50 = $5A
$000C: $70 $FF              ;     xori  $FF         ; AC = $5A ^ $FF = $A5
$000E: $04 $03              ;     mv    t0, a0      ; save $A5 to t0
$0010: $30 $00              ;     li    $00         ; AC = 0
$0012: $38 $03              ;     mv    a0, t0      ; AC = RAM[$03] = $A5
$0014: $30 $25              ;     li    $25         ; AC = $25
$0016: $04 $00 $18 $00      ;     sll               ; AC = $25 + $25 = $4A
$001A: $02 $20              ;     beq   skip1       ; AC=$4A != 0, should NOT branch
$001C: $30 $01              ;     li    $01         ; AC = 1 (this should execute)
$001E: $01 $22              ;     j     test11
$0020: $30 $FF              ;     li    $FF         ; should NOT reach here
$0022: $30 $00              ;     li    $00         ; AC = 0
$0024: $02 $28              ;     beq   test12      ; Z=1, should branch
$0026: $30 $FF              ;     li    $FF         ; should NOT reach here
$0028: $30 $03              ;     li    $03         ; AC = 3
$002A: $90 $01              ;     subi  $01         ; AC--
$002C: $82 $2A              ;     bne   loop        ; if AC != 0, loop back
$002E: $30 $77              ;     li    $77         ; AC = $77
$0030: $04 $20              ;     sb    $20         ; RAM[$20] = $77
$0032: $30 $00              ;     li    $00         ; AC = 0
$0034: $38 $20              ;     lb    $20         ; AC = RAM[$20] = $77
$0036: $01 $36              ;     hlt

