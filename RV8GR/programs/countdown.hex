$8000: $30 $05              ;     li    5           ; AC = 5
$8002: $04 $03              ;     mv    t0, a0      ; save to r3 (RAM[$03])
$8004: $90 $01              ;     subi  1           ; AC = AC - 1
$8006: $04 $03              ;     mv    t0, a0      ; save counter
$8008: $82 $04              ;     bne   loop        ; if AC != 0, loop back
$800A: $01 $0A              ;     hlt               ; stop